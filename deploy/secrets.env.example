# =============================================================================
# ScanOrbit Docker Secrets
# =============================================================================
# This file lists all secrets that should be stored in deploy/secrets/ files.
# Copy this file, fill in the values, and run:
#   cd deploy && ./scripts/setup-secrets.sh secrets.env
#
# After running, DELETE this file immediately:
#   rm -f secrets.env
#
# Generate strong values with: openssl rand -hex 32
# =============================================================================

# --- Database ---
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://scanorbit:YOUR_POSTGRES_PASSWORD@postgres:5432/scanorbit?sslmode=require

# --- Redis ---
REDIS_PASSWORD=
REDIS_URL=rediss://:YOUR_REDIS_PASSWORD@redis:6379

# --- JWT ---
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- Encryption Keys ---
TOTP_ENCRYPTION_KEY=
OAUTH_ENCRYPTION_KEY=

# --- OAuth ---
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AWS ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Email ---
SMTP_PASS=

# --- Backups (Scaleway) ---
BACKUP_ENCRYPTION_KEY=
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
