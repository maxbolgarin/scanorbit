# =============================================================================
# ScanOrbit Docker Secrets
# =============================================================================
# This file lists all secrets that should be stored in deploy/secrets/ files.
# Copy this file, fill in the values, and run:
#   cd deploy && ./scripts/setup-secrets.sh secrets.env
#
# After running, DELETE this file immediately:
#   rm -f secrets.env
#
# Generate strong values with: openssl rand -hex 32
# =============================================================================

# --- Database (admin) ---
POSTGRES_PASSWORD=

# --- Per-service database users ---
# Passwords (generate each with: openssl rand -hex 32)
SO_API_PASSWORD=
SO_MIGRATE_PASSWORD=
SO_SCANNER_PASSWORD=
SO_ANALYZER_PASSWORD=
SO_BACKUP_PASSWORD=
SO_EXPORTER_PASSWORD=
SO_UMAMI_PASSWORD=

# Database URLs (replace PASS with the corresponding password above)
SO_API_DATABASE_URL=postgresql://so_api:PASS@postgres:5432/scanorbit?sslmode=require
SO_MIGRATE_DATABASE_URL=postgresql://so_migrate:PASS@postgres:5432/scanorbit?sslmode=require
SO_SCANNER_DATABASE_URL=postgresql://so_scanner:PASS@postgres:5432/scanorbit?sslmode=require
SO_ANALYZER_DATABASE_URL=postgresql://so_analyzer:PASS@postgres:5432/scanorbit?sslmode=require

# --- Redis ---
REDIS_PASSWORD=
REDIS_URL=rediss://:YOUR_REDIS_PASSWORD@redis:6379

# --- JWT ---
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- Encryption Keys ---
TOTP_ENCRYPTION_KEY=
OAUTH_ENCRYPTION_KEY=

# --- OAuth ---
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AWS ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Email (Resend) ---
RESEND_WEBHOOK_SECRET=

# --- Backups (Scaleway) ---
BACKUP_ENCRYPTION_KEY=
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
