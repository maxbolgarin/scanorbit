# Global options
{
	email {$ADMIN_EMAIL}
}

# Common hardening: block dotfiles and obvious scanner probes early (before upstreams)
(block_scanners) {
	# Deny any dotfile paths (e.g. /.env, /.git, /.vscode, etc.)
	@dotfiles path_regexp dotfiles ^/\.
	respond @dotfiles 404

	# Common vulnerability scanner paths (safe to 404 for SPA + API)
	@scanpaths path \
		/_all_dbs \
		/actuator* \
		/api-docs* \
		/debug* \
		/ecp* \
		/info.php \
		/login.action \
		/owa* \
		/server-status* \
		/swagger* \
		/swagger-ui* \
		/telescope* \
		/v2/api-docs* \
		/v3/api-docs* \
		/webjars* \
		/wp-* \
		/wp-admin* \
		/wp-login* \
		/xmlrpc.php
	respond @scanpaths 404
}

# Landing page - root domain
{$DOMAIN} {
	import block_scanners
	header /* {
		-Server
		-Via
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	# Umami tracking (dashboard not public — access via SSH tunnel on :3002)
	@umami path /t.js /collect
	reverse_proxy @umami umami:3000

	# Proxy API calls from landing page (newsletter subscribe, etc.)
	handle_path /api/* {
		reverse_proxy api:4000
	}

	reverse_proxy landing:80
}

# WWW redirect to root
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}

# React App - app subdomain
app.{$DOMAIN} {
	import block_scanners
	header /* {
		-Server
		-Via
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://api.scanorbit.cloud; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	# Umami tracking (dashboard not public — access via SSH tunnel on :3002)
	@umami path /t.js /collect
	reverse_proxy @umami umami:3000

	# Route API paths to the API service (so they don't hit the SPA's nginx).
	handle_path /api/* {
		reverse_proxy api:4000
	}
	@api_paths path /auth/* /orgs* /aws/* /resources* /findings* /gdpr* /stripe* /newsletter* /webhooks*
	reverse_proxy @api_paths api:4000

	# Everything else is the SPA.
	reverse_proxy app:80
}

# API - api subdomain
api.{$DOMAIN} {
	import block_scanners
	header /* {
		-Server
		-Via
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# Block internal-only endpoints from public access
	@internal_endpoints path /metrics /status
	respond @internal_endpoints 404

	reverse_proxy api:4000
}

# maxbolgarin.com - both www and non-www (Caddy will get one cert covering both)
maxbolgarin.com, www.maxbolgarin.com {
	import block_scanners
	header /* {
		-Server
		-Via
	}
	reverse_proxy maxbolgarin:80
}