# Global options
{
	email {$ADMIN_EMAIL}
}

# Common hardening: block dotfiles and obvious scanner probes early (before upstreams)
(block_scanners) {
	# Deny any dotfile paths (e.g. /.env, /.git, /.vscode, etc.)
	@dotfiles path_regexp dotfiles ^/\.
	respond @dotfiles 404

	# Common vulnerability scanner paths (safe to 404 for SPA + API)
	@scanpaths path \
		/_all_dbs \
		/actuator* \
		/api-docs* \
		/debug* \
		/ecp* \
		/info.php \
		/login.action \
		/owa* \
		/server-status* \
		/swagger* \
		/swagger-ui* \
		/telescope* \
		/v2/api-docs* \
		/v3/api-docs* \
		/webjars* \
		/wp-* \
		/wp-admin* \
		/wp-login* \
		/xmlrpc.php
	respond @scanpaths 404
}

# Landing page - root domain
{$DOMAIN} {
	import block_scanners
	reverse_proxy landing:80
}

# WWW redirect to root
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}

# React App - app subdomain
app.{$DOMAIN} {
	import block_scanners
	# Route API paths to the API service (so they don't hit the SPA's nginx).
	@api_paths path /api/* /auth/* /orgs* /aws/* /resources* /findings*
	reverse_proxy @api_paths api:4000

	# Everything else is the SPA.
	reverse_proxy app:80
}

# API - api subdomain
api.{$DOMAIN} {
	import block_scanners
	reverse_proxy api:4000
}

# maxbolgarin.com - both www and non-www (Caddy will get one cert covering both)
maxbolgarin.com, www.maxbolgarin.com {
	import block_scanners
	reverse_proxy maxbolgarin:80
}