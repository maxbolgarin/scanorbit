# =============================================================================
# ScanOrbit — Self-host environment (docker-compose.selfhost.yml)
# =============================================================================
# Copy this file to `.env` (or `.env.selfhost`) and edit the four secrets
# below. Then run:
#
#     docker compose -f docker-compose.selfhost.yml up -d
#
# The OSS build hard-codes every organization to the TEAM tier and disables
# Stripe / marketing flows, so the only mandatory values are the random
# secrets at the top.
# =============================================================================


# --- Required: random secrets (generate each with `openssl rand -hex 32`) ---
JWT_SECRET=
JWT_REFRESH_SECRET=
TOTP_ENCRYPTION_KEY=
OAUTH_ENCRYPTION_KEY=

# --- App URL ---
# Public URL of the web UI. Used for cookies and email links.
FRONTEND_URL=http://localhost:8080
# Host port the React app is published on.
APP_PORT=8080

# --- Database (defaults are fine for self-hosting) ---
POSTGRES_USER=scanorbit
POSTGRES_PASSWORD=scanorbit
POSTGRES_DB=scanorbit

# --- AWS scanning (used by scanner/analyzer to assume customer roles) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Optional: transactional email via Resend ---
# When unset, ScanOrbit prints email content (verification codes, password
# reset links) to the API container logs:
#   docker compose -f docker-compose.selfhost.yml logs -f api
RESEND_API_KEY=
EMAIL_FROM=ScanOrbit <noreply@localhost>

# --- Optional tuning ---
LOG_LEVEL=info
SCAN_CONCURRENCY=10
SCAN_TIMEOUT_MINUTES=60
