{
  "name": "@scanorbit/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp -r src/emails/templates dist/emails/templates",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules",
    "db:generate": "drizzle-kit generate --config=drizzle.config.cjs",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:kit": "drizzle-kit migrate --config=drizzle.config.cjs",
    "db:reset": "tsx src/db/reset.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-sts": "^3.1002.0",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.45.1",
    "google-auth-library": "^10.6.1",
    "handlebars": "^4.7.8",
    "hono": "^4.12.5",
    "ioredis": "^5.10.0",
    "jose": "^6.1.3",
    "otpauth": "^9.5.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "prom-client": "^15.1.3",
    "resend": "^6.9.3",
    "stripe": "^20.4.0",
    "svix": "^1.88.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@scanorbit/eslint-config": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
