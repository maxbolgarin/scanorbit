                <tr class="border-b border-midnight/40">
                  <td class="py-3.5 pr-6 font-mono text-warning-orange text-xs">403</td>
                  <td class="py-3.5 pr-6 font-mono text-cloud-gray text-xs">Forbidden</td>
                  <td class="py-3.5 text-slate-gray text-xs">Organization does not have Team plan access</td>
                </tr>
                <tr class="border-b border-midnight/40">
                  <td class="py-3.5 pr-6 font-mono text-warning-orange text-xs">404</td>
                  <td class="py-3.5 pr-6 font-mono text-cloud-gray text-xs">Not Found</td>
                  <td class="py-3.5 text-slate-gray text-xs">The requested resource or finding does not exist</td>
                </tr>
                <tr class="border-b border-midnight/40">
                  <td class="py-3.5 pr-6 font-mono text-alert-red text-xs">429</td>
                  <td class="py-3.5 pr-6 font-mono text-cloud-gray text-xs">Too Many Requests</td>
                  <td class="py-3.5 text-slate-gray text-xs">Rate limit of 100 req/min per org exceeded</td>
                </tr>
                <tr>
                  <td class="py-3.5 pr-6 font-mono text-alert-red text-xs">500</td>
                  <td class="py-3.5 pr-6 font-mono text-cloud-gray text-xs">Internal Server Error</td>
                  <td class="py-3.5 text-slate-gray text-xs">Unexpected server error — contact support</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

      </main>
    </div>
  </div>

  <Footer />
</Layout>

<script>
  // Copy button functionality
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const pre = btn.closest('.group')?.querySelector('pre');
      if (!pre) return;
      try {
        await navigator.clipboard.writeText(pre.innerText);
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        btn.classList.add('text-neon-green');
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove('text-neon-green');
        }, 2000);
      } catch {
        // Clipboard not available
      }
    });
  });

  // Active TOC highlight on scroll
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
  const sectionIds = Array.from(tocLinks).map((l) => l.dataset.section!).filter(Boolean);

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          tocLinks.forEach((link) => {
            const active = link.dataset.section === id;
            link.classList.toggle('text-cyber-cyan', active);
            link.classList.toggle('bg-cyber-cyan/5', active);
            link.classList.toggle('text-slate-gray', !active);
          });
        }
      });
    },
    { rootMargin: '-20% 0% -70% 0%', threshold: 0 }
  );

  sectionIds.forEach((id) => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });
</script>
