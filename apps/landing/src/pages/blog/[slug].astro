---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter(
    (post) => !post.data.draft
  );
  return posts.map((post) => ({
    params: { slug: post.data.link },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const pubDateISO = post.data.pubDate.toISOString();
const modDateISO = post.data.updatedDate?.toISOString();
const pubDateFormatted = post.data.pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const modDateFormatted = post.data.updatedDate?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Related posts (same tags, excluding current)
const allPosts = (await getCollection("blog")).filter(
  (p) => !p.data.draft && p.data.link !== post.data.link
);
const relatedPosts = allPosts
  .map((p) => ({
    post: p,
    score: p.data.tags.filter((t) => post.data.tags.includes(t)).length,
  }))
  .filter((p) => p.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map((p) => p.post);

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: Astro.site?.href,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: new URL("/blog", Astro.site).href,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: new URL(`/blog/${post.data.link}`, Astro.site).href,
    },
  ],
};
---

<Layout
  title={`${post.data.title} | ScanOrbit Blog`}
  description={post.data.description}
  image={post.data.image?.url}
  type="article"
  publishedTime={pubDateISO}
  modifiedTime={modDateISO}
  author={post.data.author}
  tags={post.data.tags}
>
  <Header />
  <main class="pt-24">
    <section class="py-16 bg-deep-space relative overflow-hidden">
      <!-- Background glow effects -->
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-orbit-purple/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-cyber-cyan/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/3"></div>

      <div class="container mx-auto px-6 max-w-3xl relative z-10">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex items-center gap-2 text-sm text-slate-gray">
            <li><a href="/" class="hover:text-orbit-purple transition-colors">Home</a></li>
            <li class="text-slate-gray/40">/</li>
            <li><a href="/blog" class="hover:text-orbit-purple transition-colors">Blog</a></li>
            <li class="text-slate-gray/40">/</li>
            <li class="text-cloud-gray truncate max-w-[200px]">{post.data.title}</li>
          </ol>
        </nav>

        <!-- Article Header -->
        <header class="mb-10">
          <div class="flex flex-wrap gap-2 mb-4">
            {post.data.tags.map((tag) => (
              <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-orbit-purple/20 text-cyber-cyan border border-cyber-cyan/30">
                {tag}
              </span>
            ))}
          </div>

          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 leading-tight">
            <span class="bg-gradient-to-r from-orbit-purple to-cyber-cyan bg-clip-text text-transparent">
              {post.data.title}
            </span>
          </h1>

          <p class="text-lg text-slate-gray mb-6">{post.data.description}</p>

          <div class="flex flex-wrap items-center gap-4 text-sm text-slate-gray border-t border-b border-orbit-purple/15 py-4">
            <span>{post.data.author}</span>
            <span class="text-slate-gray/40">|</span>
            <time datetime={pubDateISO}>{pubDateFormatted}</time>
            {modDateFormatted && (
              <>
                <span class="text-slate-gray/40">|</span>
                <span>Updated: <time datetime={modDateISO}>{modDateFormatted}</time></span>
              </>
            )}
          </div>
        </header>

        <!-- Article Content -->
        <article class="blog-content">
          <Content />
        </article>

        <!-- Back to Blog -->
        <div class="mt-12 pt-8 border-t border-slate-gray/10">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-orbit-purple hover:text-orbit-purple/80 hover:underline transition-colors"
          >
            &larr; Back to all articles
          </a>
        </div>

        <!-- Related Posts -->
        {relatedPosts.length > 0 && (
          <div class="mt-12 pt-8 border-t border-slate-gray/10">
            <h2 class="text-2xl font-semibold text-cloud-gray mb-6">Related Articles</h2>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {relatedPosts.map((related) => (
                <a
                  href={`/blog/${related.data.link}`}
                  class="block p-4 rounded-xl border border-slate-gray/10 hover:border-orbit-purple/40 bg-midnight/30 transition-all duration-300 hover:shadow-[0_0_20px_rgba(107,70,193,0.08)]"
                >
                  <h3 class="font-medium text-cloud-gray mb-2 line-clamp-2">
                    {related.data.title}
                  </h3>
                  <time
                    datetime={related.data.pubDate.toISOString()}
                    class="text-sm text-slate-gray"
                  >
                    {related.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

<style is:global>
  .blog-content {
    color: var(--color-slate-gray);
    line-height: 1.8;
    font-size: 1.0625rem;
  }

  .blog-content h2 {
    color: var(--color-cloud-gray);
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-orbit-purple) 25%, transparent);
  }

  .blog-content h3 {
    color: var(--color-cloud-gray);
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .blog-content p {
    margin-bottom: 1.25rem;
  }

  .blog-content strong {
    color: var(--color-cloud-gray);
  }

  .blog-content ul,
  .blog-content ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .blog-content li {
    margin-bottom: 0.5rem;
  }

  .blog-content ul {
    list-style-type: disc;
  }

  .blog-content ol {
    list-style-type: decimal;
  }

  .blog-content a {
    color: var(--color-cyber-cyan);
    text-decoration: none;
    transition: text-decoration 0.2s;
  }

  .blog-content a:hover {
    text-decoration: underline;
  }

  .blog-content hr {
    border: none;
    border-top: 1px solid var(--legal-border);
    margin: 2rem 0;
  }

  .blog-content blockquote {
    border-left: 3px solid var(--color-orbit-purple);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-cloud-gray);
    font-style: italic;
  }

  .blog-content code {
    background-color: var(--color-midnight);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
    font-family: var(--font-mono);
  }

  .blog-content pre {
    background-color: var(--color-midnight);
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    border: 1px solid var(--legal-border-subtle);
  }

  .blog-content pre code {
    background: none;
    padding: 0;
    border-radius: 0;
  }

  .blog-content img {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }

  .blog-content table {
    width: 100%;
    margin: 1.5rem 0;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .blog-content thead {
    background-color: var(--color-midnight);
  }

  .blog-content th {
    color: var(--color-cloud-gray);
    font-weight: 600;
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--legal-border-strong);
  }

  .blog-content td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--legal-border-subtle);
  }

  .blog-content tbody tr:hover {
    background-color: var(--legal-hover-bg);
  }
</style>
