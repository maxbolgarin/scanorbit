---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const blogJsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "ScanOrbit Blog",
  description:
    "Insights on AWS cloud security, infrastructure scanning, cost optimization, and compliance best practices.",
  url: new URL("/blog", Astro.site).href,
  publisher: {
    "@type": "Organization",
    name: "ScanOrbit",
    url: Astro.site?.href,
  },
};
---

<Layout
  title="ScanOrbit Blog - AWS Cloud Security & Infrastructure Insights"
  description="Insights on AWS cloud security, infrastructure scanning, cost optimization, and compliance best practices from the ScanOrbit team."
>
  <Header />
  <main class="pt-24">
    <section class="py-16 bg-deep-space relative overflow-hidden">
      <!-- Background glow effects -->
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-orbit-purple/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-cyber-cyan/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/3"></div>

      <div class="container mx-auto px-6 max-w-4xl relative z-10">
        <!-- Page Header -->
        <div class="mb-12">
          <h1 class="text-4xl md:text-5xl font-bold mb-4">
            <span
              class="bg-gradient-to-r from-orbit-purple to-cyber-cyan bg-clip-text text-transparent"
            >
              Blog
            </span>
          </h1>
          <p class="text-lg text-slate-gray max-w-2xl">
            Insights on AWS cloud security, infrastructure scanning, cost
            optimization, and compliance best practices.
          </p>
          <div class="mt-4 w-24 h-1 bg-gradient-to-r from-orbit-purple to-cyber-cyan rounded-full"></div>
        </div>

        <!-- Posts List -->
        {
          posts.length === 0 ? (
            <p class="text-slate-gray">No posts yet. Check back soon!</p>
          ) : (
            <div class="space-y-8">
              {posts.map((post) => (
                <article class="group border border-slate-gray/10 rounded-xl p-6 hover:border-orbit-purple/40 transition-all duration-300 bg-midnight/30 hover:shadow-[0_0_30px_rgba(107,70,193,0.08)]">
                  <a href={`/blog/${post.id}`} class="block">
                    <div class="flex flex-wrap items-center gap-3 mb-3 text-sm">
                      <time
                        datetime={post.data.pubDate.toISOString()}
                        class="text-slate-gray"
                      >
                        {post.data.pubDate.toLocaleDateString("en-US", {
                          year: "numeric",
                          month: "long",
                          day: "numeric",
                        })}
                      </time>
                    </div>
                    <h2 class="text-xl md:text-2xl font-semibold text-cloud-gray group-hover:text-orbit-purple transition-colors mb-3">
                      {post.data.title}
                    </h2>
                    <p class="text-slate-gray mb-4 line-clamp-2">
                      {post.data.description}
                    </p>
                    <div class="flex flex-wrap gap-2">
                      {post.data.tags.map((tag) => (
                        <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-orbit-purple/20 text-cyber-cyan border border-cyber-cyan/30">
                          {tag}
                        </span>
                      ))}
                    </div>
                  </a>
                </article>
              ))}
            </div>
          )
        }
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script type="application/ld+json" set:html={JSON.stringify(blogJsonLd)} />
