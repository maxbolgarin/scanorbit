---
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import LegalNav from "../components/LegalNav.astro";

const entry = await getEntry("legal", "cookie-policy");
const { Content } = await entry.render();
---

<Layout
  title={`${entry.data.title} - ScanOrbit`}
  description={entry.data.description}
>
  <Header />
  <main id="main-content" class="pt-24">
    <section class="py-16 bg-deep-space">
      <div class="container mx-auto px-6 max-w-4xl">
        <!-- Header -->
        <div class="mb-12">
          <h1 class="text-4xl md:text-5xl font-bold mb-4">
            <span class="bg-gradient-to-r from-orbit-purple to-cyber-cyan bg-clip-text text-transparent">
              {entry.data.title}
            </span>
          </h1>
          <p class="text-slate-gray">
            Last Updated: {entry.data.lastUpdated}
          </p>
        </div>

        <!-- Content -->
        <article class="legal-content">
          <Content />
        </article>

        <LegalNav current="/cookies" />
      </div>
    </section>
  </main>
  <Footer />
</Layout>
