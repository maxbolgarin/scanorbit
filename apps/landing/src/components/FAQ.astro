---
import { Icon } from "astro-icon/components";

const faqs = [
  {
    question: "How do you prevent unauthorized access?",
    answer: "We use a read-only IAM role with zero write permissions. Our policy only includes Describe* and List* actions - we literally cannot modify, create, or delete any resources in your AWS account.",
  },
  {
    question: "Is my data safe?",
    answer: "All data is encrypted at rest (AES-256) and in transit (TLS 1.3). We only store metadata about your resources - never the actual data inside them. Everything is hosted in EU data centers.",
  },
  {
    question: "Do you modify any AWS resources?",
    answer: "Never. We only scan and report. Our IAM role has no write permissions. We can't start, stop, create, or delete anything. It's technically impossible for us to make changes.",
  },
  {
    question: "What's included in the Free plan?",
    answer: "The Free plan includes 1 AWS account, all scanner types, single successful scan, overall health score. It's perfect for trying out ScanOrbit and getting started with basic infrastructure monitoring.",
  },
  {
    question: "What's the difference between Pro and Team?",
    answer: "Pro (€19/month) is for individual DevOps engineers - you get 1 AWS account, access to all investigating tools, unlimited scans with cooldown, data retention. Team (€79/month) allows to add many AWS accounts, API access, scan priority, team collaboration features, and priority email support.",
  },
  {
    question: "Is there a free trial for paid plans?",
    answer: "Yes! Both Pro and Team plans come with a 7-day free trial. Just enter your card to start — you won't be charged during the trial. You can also use our Free plan indefinitely to evaluate the core functionality.",
  },
  {
    question: "What scanner types are available?",
    answer: "We offer orphaned resource detection (EBS volumes, Elastic IPs, snapshots), SSL certificate expiry tracking, data residency compliance checks, and complete cloud inventory. Free plan has limited access, while Pro and Team get all scanner types.",
  },
  {
    question: "How long is data retained?",
    answer: "Free: 7 days. Pro: 90 days. Team is negotiable. TTL counting starts after the last scan. You can request deletion at any time.",
  },
  {
    question: "Can I connect multiple AWS accounts?",
    answer: "Free and Pro plans support 1 AWS account. Team plan supports many AWS accounts with consolidated dashboards and cross-account reporting.",
  },
  {
    question: "Can I cancel anytime?",
    answer: "Yes, you can cancel your subscription at any time. You'll continue to have access until the end of your billing period. No long-term contracts or cancellation fees.",
  },
  {
    question: "Do you support other cloud providers?",
    answer: "Currently we support AWS only. Azure and GCP support is on our roadmap. Contact us if you're interested in multi-cloud support.",
  },
];
---

<section id="faq" class="py-24 bg-deep-space relative">
  <div class="container mx-auto px-6">
    <div class="max-w-3xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold mb-6">
          <span class="text-cloud-gray">Frequently asked </span>
          <span class="bg-gradient-to-r from-orbit-purple to-cyber-cyan bg-clip-text text-transparent">
            questions
          </span>
        </h2>
        <p class="text-lg text-slate-gray">
          Everything you need to know about ScanOrbit security and features.
        </p>
      </div>

      <!-- FAQ items -->
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-midnight rounded-xl border border-border-subtle hover:border-cyber-cyan/20 transition-colors">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
              <h3 class="font-medium text-cloud-gray pr-4">{faq.question}</h3>
              <Icon name="lucide:chevron-down" class="w-5 h-5 text-slate-gray group-open:rotate-180 transition-transform flex-shrink-0" />
            </summary>
            <div class="px-6 pb-6 pt-0">
              <p class="text-slate-gray">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>

      <!-- Contact CTA -->
      <div class="mt-12 text-center">
        <p class="text-slate-gray mb-4">Still have questions?</p>
        <a
          href="mailto:hello@scanorbit.cloud"
          class="text-cyber-cyan hover:underline"
        >
          Contact us directly
        </a>
      </div>
    </div>
  </div>
</section>
