---
import { ChevronDown } from "lucide-astro";

const faqs = [
  {
    question: "How do you prevent unauthorized access?",
    answer: "We use a read-only IAM role with zero write permissions. Our policy only includes Describe* and List* actions - we literally cannot modify, create, or delete any resources in your AWS account.",
  },
  {
    question: "Is my data safe?",
    answer: "All data is encrypted at rest (AES-256) and in transit (TLS 1.3). We only store metadata about your resources - never the actual data inside them. Everything is hosted in EU data centers.",
  },
  {
    question: "Do you modify any AWS resources?",
    answer: "Never. We only scan and report. Our IAM role has no write permissions. We can't start, stop, create, or delete anything. It's technically impossible for us to make changes.",
  },
  {
    question: "How long is data retained?",
    answer: "Free tier: 7 days. Pro: 90 days. Enterprise: custom retention. You can request deletion at any time, and all data is permanently removed within 30 days.",
  },
  {
    question: "Can we use this with multi-account AWS organizations?",
    answer: "Yes! Free tier supports 1 account. Pro supports up to 5 accounts with consolidated dashboards. Enterprise offers unlimited accounts with organization-wide views.",
  },
  {
    question: "Is there a trial period?",
    answer: "Our free tier is perpetual - no credit card required, no time limit. You get full access to all scanner types with 1 AWS account. Upgrade to Pro only when you need more accounts.",
  },
];
---

<section id="faq" class="py-24 bg-deep-space relative">
  <div class="container mx-auto px-6">
    <div class="max-w-3xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold mb-6">
          <span class="text-cloud-gray">Frequently asked </span>
          <span class="bg-gradient-to-r from-orbit-purple to-cyber-cyan bg-clip-text text-transparent">
            questions
          </span>
        </h2>
        <p class="text-lg text-slate-gray">
          Everything you need to know about ScanOrbit security and features.
        </p>
      </div>

      <!-- FAQ items -->
      <div class="space-y-4">
        {faqs.map((faq, index) => (
          <details class="group bg-midnight rounded-xl border border-midnight hover:border-cyber-cyan/20 transition-colors">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
              <h3 class="font-medium text-cloud-gray pr-4">{faq.question}</h3>
              <ChevronDown class="w-5 h-5 text-slate-gray group-open:rotate-180 transition-transform flex-shrink-0" />
            </summary>
            <div class="px-6 pb-6 pt-0">
              <p class="text-slate-gray">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>

      <!-- Contact CTA -->
      <div class="mt-12 text-center">
        <p class="text-slate-gray mb-4">Still have questions?</p>
        <a
          href="mailto:hello@scanorbit.io"
          class="text-cyber-cyan hover:underline"
        >
          Contact us directly
        </a>
      </div>
    </div>
  </div>
</section>
