---
import { Icon } from "astro-icon/components";

const faqSchemaLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [] as { "@type": string; name: string; acceptedAnswer: { "@type": string; text: string } }[],
};

const faqs = [
  {
    question: "Is ScanOrbit really free?",
    answer: "Yes. ScanOrbit is open source — there is no SaaS, no signup, no paywalled tier. You clone the repository, run it on your own infrastructure, and keep full control of your data and operating costs.",
  },
  {
    question: "How do I deploy ScanOrbit?",
    answer: "The repository ships with a docker-compose stack and Ansible playbooks for production. Follow the Production Deployment section of the README to spin up the API, app, workers, PostgreSQL, and Redis on any VM that runs Docker.",
  },
  {
    question: "What are the system requirements?",
    answer: "A small Linux VM (2 vCPU / 4 GB RAM is plenty for a single AWS account), Docker and docker-compose, plus outbound HTTPS access to the AWS APIs you want to scan. Postgres and Redis come bundled in the compose stack.",
  },
  {
    question: "How do you prevent unauthorized access to my AWS account?",
    answer: "ScanOrbit uses a read-only IAM role with zero write permissions. The policy only includes Describe* and List* actions — the scanner literally cannot modify, create, or delete any resources. You generate the role yourself, and you can revoke it at any time.",
  },
  {
    question: "Does ScanOrbit modify any AWS resources?",
    answer: "Never. The scanner only reads metadata. The recommended IAM role has no write permissions, so it's technically impossible for the tool to make changes to your account.",
  },
  {
    question: "Where is my data stored?",
    answer: "Wherever you deploy it. Because ScanOrbit is self-hosted, all scan results live in the PostgreSQL database on your server. Data never leaves your infrastructure unless you configure an external integration yourself.",
  },
  {
    question: "What scanner types are available?",
    answer: "Orphaned resource detection (EBS volumes, Elastic IPs, snapshots), SSL certificate expiry tracking, data residency compliance checks, security misconfiguration checks, and complete cloud inventory with a dependency graph.",
  },
  {
    question: "Can I scan multiple AWS accounts?",
    answer: "Yes. There are no artificial seat or account limits — connect as many AWS accounts as your hardware can comfortably scan. The dashboard supports consolidated views across accounts.",
  },
  {
    question: "How can I contribute or report issues?",
    answer: "Open an issue or pull request on the GitHub repository. The project is MIT-licensed and welcomes contributions: new scanners, additional cloud providers, documentation improvements, and bug reports are all appreciated.",
  },
  {
    question: "Do you support other cloud providers?",
    answer: "Currently AWS only. Azure and GCP support are on the roadmap. If you'd like to help build them, contributions are welcome on GitHub.",
  },
];

for (const faq of faqs) {
  faqSchemaLd.mainEntity.push({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  });
}
---

<section id="faq" class="py-24 bg-deep-space relative">
  <div class="container mx-auto px-6">
    <div class="max-w-3xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold mb-6">
          <span class="text-cloud-gray">Frequently asked </span>
          <span class="bg-gradient-to-r from-orbit-purple to-cyber-cyan bg-clip-text text-transparent">
            questions
          </span>
        </h2>
        <p class="text-lg text-slate-gray">
          Everything you need to know about ScanOrbit security and features.
        </p>
      </div>

      <!-- FAQ items -->
      <div class="space-y-4">
        {faqs.map((faq, i) => (
          <details class="group bg-midnight rounded-xl border border-border-subtle hover:border-cyber-cyan/20 transition-colors">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none" aria-controls={`faq-answer-${i}`}>
              <h3 class="font-medium text-cloud-gray pr-4">{faq.question}</h3>
              <Icon name="lucide:chevron-down" class="w-5 h-5 text-slate-gray group-open:rotate-180 transition-transform flex-shrink-0" aria-hidden="true" />
            </summary>
            <div id={`faq-answer-${i}`} class="px-6 pb-6 pt-0">
              <p class="text-slate-gray">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>

      <!-- Contact CTA -->
      <div class="mt-12 text-center">
        <p class="text-slate-gray mb-4">Still have questions?</p>
        <a
          href="https://github.com/maxbolgarin/scanorbit/issues"
          target="_blank"
          rel="noopener noreferrer"
          class="text-cyber-cyan hover:underline"
        >
          Open an issue on GitHub
        </a>
      </div>
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchemaLd)} />
