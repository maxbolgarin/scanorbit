---
import { Icon } from "astro-icon/components";
import { appUrl } from "../config";

const problems = [
  {
    icon: "lucide:hard-drive",
    title: "Orphaned EBS volumes",
    description: "Unattached volumes silently accumulate costs every month",
    color: "text-warning-orange",
  },
  {
    icon: "lucide:shield-alert",
    title: "SSL certificates expiring",
    description: "Causing outages and security vulnerabilities",
    color: "text-alert-red",
  },
  {
    icon: "lucide:globe",
    title: "Data in wrong regions",
    description: "Flowing to non-EU regions, risking GDPR fines",
    color: "text-alert-red",
  },
  {
    icon: "lucide:tag",
    title: "Untagged resources",
    description: "Hiding true cloud costs and blocking governance",
    color: "text-warning-orange",
  },
];
---

<section class="py-24 bg-deep-space relative">
  <div class="container mx-auto px-6">
    <div class="max-w-3xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-cloud-gray">
          What's Hiding in Your AWS Account?
        </h2>
        <p class="text-lg text-slate-gray">
          Most teams don't have visibility into orphaned resources, expiring certificates, or compliance violations until it's too late. ScanOrbit shows you exactly what's in your account.
        </p>
      </div>

      <!-- Problems list -->
      <div class="mb-10">
        <p class="text-slate-gray text-sm uppercase tracking-wider mb-6">Common issues we find</p>
        <div class="border-t border-slate-gray/20 pt-6 space-y-6">
          {problems.map((problem) => (
            <div class="flex items-start gap-4">
              <div class={`p-2 rounded-lg bg-midnight ${problem.color}`}>
                <Icon name={problem.icon} class="w-5 h-5" />
              </div>
              <div>
                <h3 class="font-semibold text-cloud-gray mb-1">{problem.title}</h3>
                <p class="text-slate-gray text-sm">{problem.description}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="border-t border-slate-gray/20 mt-6"></div>
      </div>

      <!-- CTA -->
      <div class="text-center">
        <p class="text-cloud-gray mb-6">See what's actually in your AWS account.</p>
        <a
          href={appUrl}
          class="group inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-orbit-purple to-cyber-cyan rounded-lg font-semibold transition-all duration-300 hover:shadow-[0_0_30px_rgba(0,212,255,0.4)]"
        >
          Start Free Scan
          <Icon name="lucide:arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
        </a>
      </div>
    </div>
  </div>
</section>
