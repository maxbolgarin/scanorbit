---
import { Icon } from "astro-icon/components";
import { githubUrl, githubIssuesUrl, githubReleasesUrl, selfHostDocsUrl } from "../config";

const footerLinks = {
  features: [
    { label: "Core Features", href: "/#features" },
    { label: "Comparison", href: "/#comparison" },
    { label: "How it Works", href: "/#how-it-works" },
  ],
  resources: [
    { label: "GitHub", href: githubUrl, external: true },
    { label: "Self-host Guide", href: selfHostDocsUrl, external: true },
    { label: "Releases", href: githubReleasesUrl, external: true },
    { label: "Report an Issue", href: githubIssuesUrl, external: true },
    { label: "Blog", href: "/blog" },
    { label: "API Reference", href: "/api-reference" },
    { label: "Contact", href: "/contact" },
    { label: "FAQ", href: "/#faq" },
  ],
  legal: [
    { label: "Privacy Policy", href: "/privacy" },
    { label: "Terms of Service", href: "/terms" },
    { label: "Cookie Policy", href: "/cookies" },
    { label: "Security Policy", href: "/security" },
    { label: "DPA", href: "/dpa" },
  ],
};
---

<footer class="bg-midnight border-t border-deep-space">
  <div class="container mx-auto px-6 py-16">
    <!-- Link columns -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-8 mb-12">
      <!-- Features -->
      <div>
        <h4 class="font-semibold text-cloud-gray mb-4 text-sm uppercase tracking-wider">Features</h4>
        <ul class="space-y-3">
          {footerLinks.features.map((link) => (
            <li>
              <a href={link.href} class="text-slate-gray hover:text-cyber-cyan transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="font-semibold text-cloud-gray mb-4 text-sm uppercase tracking-wider">Resources</h4>
        <ul class="space-y-3">
          {footerLinks.resources.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-slate-gray hover:text-cyber-cyan transition-colors text-sm"
                {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="font-semibold text-cloud-gray mb-4 text-sm uppercase tracking-wider">Legal</h4>
        <ul class="space-y-3">
          {footerLinks.legal.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-slate-gray hover:text-cyber-cyan transition-colors text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Divider -->
    <div class="border-t border-deep-space"></div>

    <!-- Bottom section -->
    <div class="pt-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
      <!-- Brand & tagline -->
      <div>
        <a href="/" class="flex items-center gap-2 mb-2">
          <Icon name="lucide:orbit" class="w-7 h-7 text-cyber-cyan" aria-hidden="true" />
          <span class="text-lg font-bold bg-gradient-to-r from-orbit-purple to-cyber-cyan bg-clip-text text-transparent">
            ScanOrbit
          </span>
        </a>
        <p class="text-slate-gray text-sm mb-1">
          Open-source, self-hosted AWS scanner. Discover waste, ensure compliance.
        </p>
        <p class="text-slate-gray text-xs">
          Run it on your own infrastructure. Your data never leaves your servers.
        </p>
      </div>

      <!-- GitHub + Copyright -->
      <div class="flex flex-col md:items-end gap-3">
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 bg-deep-space hover:bg-deep-space/70 border border-slate-gray/10 rounded-lg text-sm text-cloud-gray transition-colors"
        >
          <Icon name="lucide:github" class="w-4 h-4" aria-hidden="true" />
          Star on GitHub
        </a>
        <p class="text-slate-gray text-sm">
          &copy; {new Date().getFullYear()} ScanOrbit contributors.
        </p>
      </div>
    </div>
  </div>
</footer>
