---
import { Icon } from "astro-icon/components";
import { signupUrl } from "../config";
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-midnight via-deep-space to-deep-space"></div>

  <!-- Animated scan lines -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0 bg-[linear-gradient(transparent_0%,transparent_calc(100%-1px),rgba(0,212,255,0.3)_100%)] bg-[length:100%_8px] animate-scan"></div>
  </div>

  <!-- Orbiting particles -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 hero-orb-purple rounded-full blur-3xl animate-float"></div>
  <div class="absolute bottom-1/4 right-1/4 w-80 h-80 hero-orb-cyan rounded-full blur-3xl animate-float" style="animation-delay: -3s;"></div>

  <div class="container mx-auto px-6 py-20 relative z-10">
    <div class="text-center max-w-4xl mx-auto">

      <!-- Main heading -->
      <h1 class="text-5xl md:text-7xl font-bold mb-6">
        <span class="hero-heading-primary">
          Know What's Actually
        </span>
        <br />
        <span class="bg-gradient-to-r from-orbit-purple to-cyber-cyan bg-clip-text text-transparent">
          Running in Your AWS
        </span>
      </h1>

      <!-- Subheading -->
      <p class="text-xl md:text-2xl text-slate-gray mb-10 max-w-2xl mx-auto">
        Find orphaned resources, expiring certificates, and GDPR violations. Read-only access. EU-hosted. No agents.
      </p>

      <!-- Value props row -->
      <div class="flex flex-wrap justify-center gap-6 mb-12">
        <div class="flex items-center gap-2 text-cloud-gray">
          <Icon name="lucide:clock" class="w-5 h-5 text-cyber-cyan" />
          <span>5 minute setup</span>
        </div>
        <div class="flex items-center gap-2 text-cloud-gray">
          <Icon name="lucide:search" class="w-5 h-5 text-cyber-cyan" />
          <span>Make a map of your infrastructure</span>
        </div>
        <div class="flex items-center gap-2 text-cloud-gray">
          <Icon name="lucide:shield" class="w-5 h-5 text-cyber-cyan" />
          <span>GDPR compliance checks</span>
        </div>
      </div>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
        <a
          href={signupUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group px-8 py-4 bg-orbit-purple hover:bg-orbit-purple/90 rounded-lg font-semibold text-lg text-white transition-all duration-300 hover:shadow-[0_0_30px_rgba(107,70,193,0.5)] flex items-center gap-2"
        >
          Start Free Today
          <Icon name="lucide:arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
        </a>
        <a
          href="#how-it-works"
          class="group px-8 py-4 hero-secondary-btn rounded-lg font-semibold text-lg transition-all duration-300 flex items-center gap-2"
        >
          See How It Works
        </a>
      </div>

      <!-- Trust badges -->
      <div class="flex flex-wrap items-center justify-center gap-6">
        <div class="flex items-center gap-2 px-4 py-2 hero-trust-badge rounded-full">
          <Icon name="lucide:shield" class="w-4 h-4 text-neon-green" />
          <span class="text-sm text-slate-gray">Read-only access</span>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 hero-trust-badge rounded-full">
          <Icon name="lucide:server" class="w-4 h-4 text-neon-green" />
          <span class="text-sm text-slate-gray">EU-hosted (Amsterdam)</span>
        </div>
        <div class="flex items-center gap-2 px-4 py-2 hero-trust-badge rounded-full">
          <Icon name="lucide:cloud-off" class="w-4 h-4 text-neon-green" />
          <span class="text-sm text-slate-gray">Agentless setup</span>
        </div>
      </div>
    </div>
  </div>

</section>
