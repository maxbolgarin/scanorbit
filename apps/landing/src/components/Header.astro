---
import { Icon } from "astro-icon/components";
import { signupUrl, loginUrl } from "../config";

const productDropdown = [
  { label: "How it Works", href: "/#how-it-works" },
  { label: "Features", href: "/#features" },
  { label: "Comparison", href: "/#comparison" },
  { label: "Security", href: "/#security" },
];

const resourcesDropdown = [
  { label: "API Reference", href: "/api-reference" },
  { label: "Blog", href: "/blog" },
  { label: "Contact", href: "/contact" },
];

const legalDropdown = [
  { label: "Security Policy", href: "/security" },
  { label: "Privacy Policy", href: "/privacy" },
  { label: "DPA", href: "/dpa" },
  { label: "Terms of Service", href: "/terms" },
  { label: "Cookie Policy", href: "/cookies" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-deep-space/80 backdrop-blur-md border-b border-midnight">
  <nav aria-label="Main navigation" class="container mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <Icon name="lucide:orbit" class="w-8 h-8 text-cyber-cyan group-hover:animate-spin" aria-hidden="true" />
      <span class="text-xl font-bold bg-gradient-to-r from-orbit-purple to-cyber-cyan bg-clip-text text-transparent">
        ScanOrbit
      </span>
    </a>

    <!-- Navigation -->
    <div class="hidden md:flex items-center gap-1">
      <!-- Product Dropdown -->
      <div class="relative group">
        <button class="nav-dropdown-btn flex items-center gap-1 px-4 py-2 text-slate-gray hover:text-cloud-gray transition-colors" aria-expanded="false" aria-haspopup="true">
          Product
          <Icon name="lucide:chevron-down" class="w-4 h-4 group-hover:rotate-180 transition-transform duration-200" aria-hidden="true" />
        </button>
        <div class="nav-dropdown-menu absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200" role="menu">
          <div class="bg-midnight border border-slate-gray/10 rounded-xl p-2 min-w-[200px] shadow-xl shadow-black/20">
            {productDropdown.map((item) => (
              <a
                href={item.href}
                role="menuitem"
                class="block px-4 py-2.5 rounded-lg text-sm text-slate-gray hover:text-cloud-gray hover:bg-deep-space transition-colors"
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Blog -->
      <a href="/blog" class="px-4 py-2 text-slate-gray hover:text-cloud-gray transition-colors">
        Blog
      </a>

      <!-- Pricing -->
      <a href="/#pricing" class="px-4 py-2 text-slate-gray hover:text-cloud-gray transition-colors">
        Pricing
      </a>

      <!-- Resources Dropdown -->
      <div class="relative group">
        <button class="nav-dropdown-btn flex items-center gap-1 px-4 py-2 text-slate-gray hover:text-cloud-gray transition-colors" aria-expanded="false" aria-haspopup="true">
          Resources
          <Icon name="lucide:chevron-down" class="w-4 h-4 group-hover:rotate-180 transition-transform duration-200" aria-hidden="true" />
        </button>
        <div class="nav-dropdown-menu absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200" role="menu">
          <div class="bg-midnight border border-slate-gray/10 rounded-xl p-2 min-w-[200px] shadow-xl shadow-black/20">
            {resourcesDropdown.map((item) => (
              <a
                href={item.href}
                role="menuitem"
                class="block px-4 py-2.5 rounded-lg text-sm text-slate-gray hover:text-cloud-gray hover:bg-deep-space transition-colors"
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Legal Dropdown -->
      <div class="relative group">
        <button class="nav-dropdown-btn flex items-center gap-1 px-4 py-2 text-slate-gray hover:text-cloud-gray transition-colors" aria-expanded="false" aria-haspopup="true">
          Legal
          <Icon name="lucide:chevron-down" class="w-4 h-4 group-hover:rotate-180 transition-transform duration-200" aria-hidden="true" />
        </button>
        <div class="nav-dropdown-menu absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200" role="menu">
          <div class="bg-midnight border border-slate-gray/10 rounded-xl p-2 min-w-[200px] shadow-xl shadow-black/20">
            {legalDropdown.map((item) => (
              <a
                href={item.href}
                role="menuitem"
                class="block px-4 py-2.5 rounded-lg text-sm text-slate-gray hover:text-cloud-gray hover:bg-deep-space transition-colors"
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Theme Toggle + CTA Buttons -->
    <div class="flex items-center gap-4">
      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="p-2 rounded-lg text-slate-gray hover:text-cloud-gray transition-colors"
        aria-label="Switch to light theme"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg id="theme-icon-sun" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="theme-icon-moon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>
      <a
        href={loginUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:block text-slate-gray hover:text-cloud-gray transition-colors"
      >
        Login
      </a>
      <a
        href={signupUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:block px-4 py-2 bg-orbit-purple hover:bg-orbit-purple/90 rounded-lg font-medium text-white transition-all duration-300 hover:shadow-[0_0_20px_rgba(107,70,193,0.4)]"
      >
        Get Started
      </a>
      <!-- Mobile Menu Button -->
      <button class="md:hidden p-2 text-slate-gray" id="mobile-menu-btn" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div class="hidden md:hidden bg-midnight border-t border-slate-gray/10 max-h-[calc(100dvh-4rem)] overflow-y-auto overscroll-contain" id="mobile-menu">
    <div class="container mx-auto px-6 py-4 space-y-2">
      <p class="text-xs text-slate-gray/60 uppercase tracking-wider pt-1 pb-1">Product</p>
      <a href="/#how-it-works" class="block py-2 text-slate-gray hover:text-cloud-gray">How it Works</a>
      <a href="/#features" class="block py-2 text-slate-gray hover:text-cloud-gray">Features</a>
      <a href="/#comparison" class="block py-2 text-slate-gray hover:text-cloud-gray">Comparison</a>
      <a href="/#security" class="block py-2 text-slate-gray hover:text-cloud-gray">Security</a>
      <a href="/#pricing" class="block py-2 text-slate-gray hover:text-cloud-gray">Pricing</a>
      <a href="/blog" class="block py-2 text-slate-gray hover:text-cloud-gray">Blog</a>
      <p class="text-xs text-slate-gray/60 uppercase tracking-wider pt-3 pb-1">Resources</p>
      <a href="/api-reference" class="block py-2 text-slate-gray hover:text-cloud-gray">API Reference</a>
      <a href="/blog" class="block py-2 text-slate-gray hover:text-cloud-gray">Blog</a>
      <a href="/contact" class="block py-2 text-slate-gray hover:text-cloud-gray">Contact</a>
      <p class="text-xs text-slate-gray/60 uppercase tracking-wider pt-3 pb-1">Legal</p>
      <a href="/security" class="block py-2 text-slate-gray hover:text-cloud-gray">Security Policy</a>
      <a href="/privacy" class="block py-2 text-slate-gray hover:text-cloud-gray">Privacy Policy</a>
      <a href="/dpa" class="block py-2 text-slate-gray hover:text-cloud-gray">DPA</a>
      <button id="mobile-theme-toggle" class="block py-2 text-slate-gray hover:text-cloud-gray w-full text-left">
        <span id="mobile-theme-label">Switch to Light</span>
      </button>
    </div>
  </div>
</header>

<script>
  // Mobile menu
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  mobileMenuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.toggle('hidden');
    mobileMenuBtn.setAttribute('aria-expanded', String(isOpen));
    document.body.classList.toggle('overflow-hidden', isOpen);
  });

  // Dropdown keyboard navigation
  document.querySelectorAll<HTMLButtonElement>('.nav-dropdown-btn').forEach((btn) => {
    const menu = btn.nextElementSibling as HTMLElement | null;
    if (!menu) return;
    const items = menu.querySelectorAll<HTMLAnchorElement>('[role="menuitem"]');

    function open() {
      menu!.classList.add('!opacity-100', '!visible');
      btn.setAttribute('aria-expanded', 'true');
    }
    function close() {
      menu!.classList.remove('!opacity-100', '!visible');
      btn.setAttribute('aria-expanded', 'false');
    }

    btn.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown') {
        e.preventDefault();
        open();
        items[0]?.focus();
      } else if (e.key === 'Escape') {
        close();
      }
    });

    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      if (expanded) { close(); } else { open(); items[0]?.focus(); }
    });

    items.forEach((item, i) => {
      item.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          items[Math.min(i + 1, items.length - 1)]?.focus();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          if (i === 0) { btn.focus(); close(); }
          else items[i - 1]?.focus();
        } else if (e.key === 'Escape') {
          close();
          btn.focus();
        } else if (e.key === 'Tab') {
          close();
        }
      });
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!btn.parentElement?.contains(e.target as Node)) close();
    });
  });

  // Theme toggle
  const toggle = document.getElementById('theme-toggle');
  const mobileToggle = document.getElementById('mobile-theme-toggle');
  const sunIcon = document.getElementById('theme-icon-sun');
  const moonIcon = document.getElementById('theme-icon-moon');
  const mobileLabel = document.getElementById('mobile-theme-label');

  function updateThemeUI() {
    const isDark = document.documentElement.getAttribute('data-theme') !== 'light';
    sunIcon?.classList.toggle('hidden', !isDark);
    moonIcon?.classList.toggle('hidden', isDark);
    if (mobileLabel) mobileLabel.textContent = isDark ? 'Switch to Light' : 'Switch to Dark';
    if (toggle) toggle.setAttribute('aria-label', isDark ? 'Switch to light theme' : 'Switch to dark theme');
    const meta = document.querySelector('meta[name="theme-color"]');
    if (meta) meta.setAttribute('content', isDark ? '#08080f' : '#ffffff');
  }

  function switchTheme() {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'light' ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    updateThemeUI();
  }

  toggle?.addEventListener('click', switchTheme);
  mobileToggle?.addEventListener('click', switchTheme);
  updateThemeUI();
</script>
