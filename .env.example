# =============================================================================
# ScanOrbit — Environment Configuration
# =============================================================================
#
# LOCAL DEV:  Copy to .env, fill in values, run `make dev`
# PRODUCTION: Copy to .env.prod, fill in NON-SECRET values only.
#             Secrets go into Docker secret files — see deploy/secrets.env.example
#             and run: cd deploy && ./scripts/setup-secrets.sh secrets.env
#
# =============================================================================


# =============================================================================
# 1. INFRASTRUCTURE
# =============================================================================

# --- Domain & TLS ---
DOMAIN=scanorbit.cloud
COOKIE_DOMAIN=.scanorbit.cloud
ADMIN_EMAIL=admin@scanorbit.cloud
FRONTEND_URL=https://app.scanorbit.cloud

# --- Docker / CI ---
GITHUB_REPOSITORY=maxbolgarin/scanorbit
IMAGE_TAG=latest
DOCKER_CONFIG_PATH=/home/deploy/.docker

# --- PostgreSQL ---
POSTGRES_USER=scanorbit
POSTGRES_DB=scanorbit

# --- Environment ---
NODE_ENV=production
ENVIRONMENT=production
LOG_LEVEL=info
PORT=4000

# --- Networking ---
# Trusted proxies for X-Forwarded-For (include Docker bridge subnet)
TRUSTED_PROXIES=127.0.0.1,::1,172.21.0.0/16


# =============================================================================
# 2. SECRETS (local dev only — in production use Docker secrets)
# =============================================================================
# In production, these values are read from /run/secrets/ files.
# See deploy/secrets.env.example for the full list.
# You can leave these empty in .env.prod.

# --- Database ---
POSTGRES_PASSWORD=scanorbit
DATABASE_URL=postgresql://scanorbit:scanorbit@localhost:15432/scanorbit

# --- Redis ---
REDIS_PASSWORD=
REDIS_URL=redis://localhost:16379

# --- JWT (generate with: openssl rand -hex 32) ---
JWT_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRY_MINUTES=5

# --- Encryption keys (generate with: openssl rand -hex 32) ---
TOTP_ENCRYPTION_KEY=
OAUTH_ENCRYPTION_KEY=

# --- OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# --- AWS ---
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Stripe (optional — without it, tier upgrades work without payment) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_TRIAL_DAYS=7

# --- Email ---
EMAIL_PROVIDER=smtp
EMAIL_FROM=ScanOrbit <hello@scanorbit.cloud>
RESEND_API_KEY=
SMTP_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Backups ---
BACKUP_ENCRYPTION_KEY=
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_BUCKET_NAME=scanorbit-backups
SCW_REGION=nl-ams


# =============================================================================
# 3. SERVICES (localhost-only, accessed via SSH tunnel in production)
# =============================================================================

# --- Listmonk Newsletter ---
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=
LISTMONK_API_URL=http://listmonk:9000
LISTMONK_DEFAULT_LIST_ID=1
LISTMONK_LIST_COLD_LEADS=
LISTMONK_LIST_SUBSCRIBERS=
LISTMONK_LIST_FREE_NEW=
LISTMONK_LIST_FREE_SCANNED=
LISTMONK_LIST_TRIAL_NEW=
LISTMONK_LIST_TRIAL_ACTIVE=
LISTMONK_LIST_PAID_PRO=
LISTMONK_LIST_PAID_TEAM=

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Umami Analytics ---
UMAMI_APP_SECRET=

# --- Alertmanager ---
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Watchtower ---
WATCHTOWER_NOTIFICATION_URL=

# --- Scaleway Webhooks ---
SCALEWAY_WEBHOOK_SECRET=


# =============================================================================
# 4. FRONTEND (Vite — build-time only)
# =============================================================================

VITE_API_URL=http://localhost:4000
VITE_ACCESS_TOKEN_TTL_MINUTES=5
VITE_SCANORBIT_AWS_ACCOUNT_ID=


# =============================================================================
# 5. WORKERS (Go)
# =============================================================================

SCAN_CONCURRENCY=10
SCAN_TIMEOUT_MINUTES=60
SHUTDOWN_TIMEOUT_SECONDS=30
REQUIRED_TAGS=


# =============================================================================
# 6. DATA RETENTION (GDPR, days)
# =============================================================================

RETENTION_RESOURCES_DAYS=90
RETENTION_FINDINGS_RESOLVED_DAYS=180
RETENTION_SCANS_DAYS=365
RETENTION_AUDIT_LOGS_DAYS=730
