# ScanOrbit Production Environment Variables
# Copy this file to .env.prod and fill in your values

# ===========================================
# Domain Configuration
# ===========================================
DOMAIN=scanorbit.cloud
ADMIN_EMAIL=admin@scanorbit.cloud

# ===========================================
# GitHub Container Registry
# ===========================================
# Your GitHub org/user and repo name (e.g., myorg/scanorbit)
GITHUB_REPOSITORY=YOUR_ORG/scanorbit
# Image tag (default: latest, or use commit SHA for specific version)
IMAGE_TAG=latest

# ===========================================
# Database (PostgreSQL)
# ===========================================
POSTGRES_USER=scanorbit
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=scanorbit
DATABASE_URL=postgresql://scanorbit:CHANGE_ME_STRONG_PASSWORD@postgres:5432/scanorbit

# ===========================================
# Cache & Queue (Redis)
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# API Configuration
# ===========================================
# JWT secrets (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# CORS origin (your app domain)
CORS_ORIGIN=https://app.scanorbit.cloud

# ===========================================
# AWS Configuration (for scanner workers)
# ===========================================
AWS_REGION=eu-west-1

# ===========================================
# Watchtower Notifications (optional)
# ===========================================
# Slack webhook for deployment notifications
# WATCHTOWER_NOTIFICATION_URL=slack://TOKEN@CHANNEL

# ===========================================
# Email Configuration (optional)
# ===========================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@scanorbit.cloud
# SMTP_PASSWORD=CHANGE_ME
