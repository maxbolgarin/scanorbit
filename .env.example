# =============================================================================
# ScanOrbit — Environment Configuration (OSS / self-hosted)
# =============================================================================
# Copy to .env, fill in the required values, then run:
#   docker compose up -d
#
# The only values you MUST set are the four secrets at the top.
# Everything else has sensible defaults for a single-host deployment.
# =============================================================================


# --- Required: random secrets (generate with `openssl rand -hex 32`) ---
JWT_SECRET=
JWT_REFRESH_SECRET=
TOTP_ENCRYPTION_KEY=
OAUTH_ENCRYPTION_KEY=

# --- App ---
# Public URL of the web UI. Used for cookie domain and email links.
FRONTEND_URL=http://localhost:8080
# Host port the React app is published on.
APP_PORT=8080

# --- Database (defaults are fine for self-hosting) ---
POSTGRES_USER=scanorbit
POSTGRES_PASSWORD=scanorbit
POSTGRES_DB=scanorbit

# --- AWS scanning (used by scanner/analyzer to assume customer roles) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Optional: transactional email via Resend ---
# When unset, ScanOrbit prints email content (verification codes, password
# reset links) to the API container logs:
#   docker compose logs -f api
RESEND_API_KEY=
EMAIL_FROM=ScanOrbit <noreply@localhost>

# --- Optional tuning ---
LOG_LEVEL=info
SCAN_CONCURRENCY=10
SCAN_TIMEOUT_MINUTES=60
