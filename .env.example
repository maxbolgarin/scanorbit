# =============================================================================
# ScanOrbit Environment Configuration
# =============================================================================
# Copy this file to .env and update with your values
# For production, use .env.prod with secure values

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=scanorbit
POSTGRES_PASSWORD=scanorbit
POSTGRES_DB=scanorbit

# Connection string format: postgres://user:password@host:port/database
# For Docker: use 'db' as host (container name)
# For local: use 'localhost'
DATABASE_URL=postgres://scanorbit:scanorbit@localhost:5432/scanorbit

# -----------------------------------------------------------------------------
# Redis (Cache & Job Queue)
# -----------------------------------------------------------------------------
# For Docker: use 'redis' as host (container name)
# For local: use 'localhost'
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------
# Server port
PORT=4000

# Environment: development | production
NODE_ENV=development

# JWT Configuration
# IMPORTANT: Generate a strong secret for production: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT expiration time (e.g., 7d, 24h, 60m)
JWT_EXPIRY=7d

# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:3000

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Worker Configuration (Go)
# -----------------------------------------------------------------------------
# Maximum concurrent region scans per account (default: 10)
SCAN_CONCURRENCY=10

# Graceful shutdown timeout in seconds (default: 30)
SHUTDOWN_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
# Default AWS region for STS operations
AWS_REGION=eu-central-1

# AWS credentials for local development (optional)
# In production, use IAM roles or instance profiles
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Production-Only Settings (uncomment for .env.prod)
# -----------------------------------------------------------------------------
# Domain configuration for Caddy
# DOMAIN=scanorbit.io

# SSL/TLS email for Let's Encrypt
# ADMIN_EMAIL=admin@scanorbit.io
