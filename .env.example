# =============================================================================
# ScanOrbit — Self-host environment
# =============================================================================
# Copy this file to `.env` and edit the four secrets in the "Required" block
# below. Then run:
#
#     docker compose up -d
#
# Self-hosted, Apache 2.0: every feature is unrestricted. Only the four
# secrets in the first block are mandatory — everything else has working
# defaults and can be enabled later.
# =============================================================================


# =============================================================================
# Random secrets — generate each with `openssl rand -hex 32`
# =============================================================================
# Always required (used to sign session tokens, even in single-user mode):
JWT_SECRET=
JWT_REFRESH_SECRET=

# Encrypts at-rest secrets in the DB: AWS account external IDs, webhook
# signing secrets, Slack tokens, and OAuth refresh tokens. The name says
# "OAUTH" for historical reasons but it's the generic encryption key —
# required as soon as you connect an AWS account, even with AUTH_ENABLED=false.
OAUTH_ENCRYPTION_KEY=

# Encrypts 2FA TOTP secrets at rest. Only used when AUTH_ENABLED=true AND a
# user enables 2FA from the security settings. Safe to leave blank in
# single-user mode — set it if and when you turn auth on.
TOTP_ENCRYPTION_KEY=


# =============================================================================
# Authentication mode
# =============================================================================
# Default (unset or `false`): single-user mode. The web UI skips login/signup
# entirely and every request is silently authenticated as a built-in admin
# (email: admin@local). Perfect for local development and deployments behind
# a private network / VPN.
#
# Set to `true` to require real login: email/password signup, OAuth, 2FA, etc.
#
# WARNING: do NOT expose AUTH_ENABLED=false on the public internet — anyone
# with network access becomes an admin and can connect AWS accounts.
AUTH_ENABLED=


# =============================================================================
# App URL
# =============================================================================
# Public URL of the web UI. Used for cookies and email links.
FRONTEND_URL=http://localhost:8080
# Host port the React app is published on.
APP_PORT=8080
# Set to a parent domain (e.g. `.example.com`) if the API and the app live
# on different subdomains. Leave empty for single-host deployments.
COOKIE_DOMAIN=
# Comma-separated list of IPs/CIDRs whose X-Forwarded-For header to trust.
# Set this to the IP of your reverse proxy.
TRUSTED_PROXIES=127.0.0.1,::1
# Access-token TTL in minutes. The React app proactively refreshes at half
# this value; keep both sides in sync if you change it.
ACCESS_TOKEN_EXPIRY_MINUTES=5


# =============================================================================
# Database (defaults are fine for the bundled docker-compose stack)
# =============================================================================
POSTGRES_USER=scanorbit
POSTGRES_PASSWORD=scanorbit
POSTGRES_DB=scanorbit
# Connection string used by the API process and Go workers.
# - Native dev (`make run`): `make infra` publishes Postgres on host port 15432.
# - Docker Compose (`docker compose up -d`): this value is IGNORED — each
#   container builds its own URL from POSTGRES_USER/PASSWORD/DB pointing at
#   the internal `db:5432` hostname.
DATABASE_URL=postgres://scanorbit:scanorbit@localhost:15432/scanorbit
# Optional: path inside the API/migrate containers to a CA bundle for the
# Postgres TLS connection. Leave empty for the default (no TLS verification).
DB_CA_CERT=


# =============================================================================
# Redis
# =============================================================================
# Connection string used by the API process and Go workers.
# - Native dev (`make run`): `make infra` publishes Redis on host port 16379.
# - Docker Compose: IGNORED — containers use the internal `redis:6379`.
REDIS_URL=redis://localhost:16379
# Optional: path inside the API container to a CA bundle for the Redis TLS
# connection. Leave empty if Redis is plaintext on the internal network.
REDIS_CA_CERT=


# =============================================================================
# AWS scanning (used by scanner/analyzer to assume customer roles)
# =============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# =============================================================================
# Optional: transactional email via Resend
# =============================================================================
# When unset, ScanOrbit prints email content (verification codes, password
# reset links) to the API container logs:
#   docker compose logs -f api
RESEND_API_KEY=
EMAIL_FROM=ScanOrbit <noreply@localhost>
# Optional: signing secret for Resend delivery webhooks (bounce/complaint
# tracking). Get it from the Resend dashboard.
RESEND_WEBHOOK_SECRET=
# Where bug reports submitted from the in-app form are emailed. Leave empty
# to disable email delivery — reports still land in the database.
BUG_REPORT_EMAIL=


# =============================================================================
# Optional: Google OAuth (sign-in with Google)
# =============================================================================
# Create credentials at https://console.cloud.google.com/apis/credentials.
# The callback URL must exactly match what's registered with Google.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback


# =============================================================================
# Optional: GitHub OAuth (sign-in with GitHub)
# =============================================================================
# Create an OAuth app at https://github.com/settings/developers.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback


# =============================================================================
# Optional: Slack integration (per-user notifications, slash commands)
# =============================================================================
# Create a Slack app at https://api.slack.com/apps. Users link their account
# via Settings → Integrations.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=


# =============================================================================
# Data retention (days). Set to 0 to disable a given cleanup.
# =============================================================================
# Resources not seen in N days are dropped from the live inventory.
RETENTION_RESOURCES_DAYS=90
# Resolved findings older than N days are dropped.
RETENTION_FINDINGS_RESOLVED_DAYS=180
# Completed scan records older than N days are dropped.
RETENTION_SCANS_DAYS=365
# Audit log rows older than N days are dropped.
RETENTION_AUDIT_LOGS_DAYS=730


# =============================================================================
# Tuning
# =============================================================================
LOG_LEVEL=info
SCAN_CONCURRENCY=10
SCAN_TIMEOUT_MINUTES=60
